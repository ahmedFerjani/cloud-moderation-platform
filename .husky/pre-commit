#!/usr/bin/env sh

# Ensure repo-local virtualenv tools are visible when hooks run from GUI clients.
PATH="$(pwd)/.venv/bin:$(pwd)/test_env/bin:$PATH"
export PATH

# ACMR = Added, Copied, Modified, Renamed (deleted files are excluded).
staged_files=$(git diff --cached --name-only --diff-filter=ACMR)

if [ -z "$staged_files" ]; then
  exit 0
fi

if [ ! -x "$(pwd)/node_modules/.bin/lint-staged" ]; then
  echo "lint-staged not found at repository root."
  echo "Run npm install in repository root to install hook dependencies."
  exit 1
fi

echo "Running staged checks (frontend/backend)..."
npx --no-install lint-staged || exit 1

# Full-project type checks are required for cross-file inference, so we gate
# them by staged language to avoid slowing unrelated commits.
if printf '%s\n' "$staged_files" | grep -q '^frontend/.*\.ts$'; then
  echo "Running frontend typecheck..."
  npm --prefix frontend run typecheck || exit 1
fi

if printf '%s\n' "$staged_files" | grep -q '^backend/.*\.py$'; then
  echo "Running backend pyright checks..."
  if command -v pyright >/dev/null 2>&1; then
    pyright --project pyrightconfig.json || exit 1
  else
    echo "pyright not found. Install backend quality deps first."
    echo "Example: uv pip install --system -r backend/requirements-ci-quality.txt"
    exit 1
  fi
fi
