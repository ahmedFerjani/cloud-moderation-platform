############################################
# OS & IDE Files
############################################
.DS_Store
Thumbs.db
.vscode/
.idea/

############################################
# Secrets & Environment Variables
############################################
.env
.env.*
*.pem
*.key

############################################
# Node.js Dependencies (Frontend + tooling)
############################################
**/node_modules/

# npm/yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*

############################################
# Angular (Frontend build artifacts)
############################################
frontend/dist/
frontend/.angular/

# cache (optional but good for CI consistency)
frontend/.cache/

############################################
# Terraform
############################################
**/.terraform/
*.tfstate
*.tfstate.*

# Terraform crash logs
crash.log

# Local variable files (can contain secrets)
*.tfvars
*.tfvars.json

############################################
# AWS / Serverless artifacts
############################################
.aws-sam/
.serverless/
backend/samconfig*

# packaged deployment artifacts
*.zip

############################################
# Python - Virtual Environment
############################################
.venv/
venv/
ENV/

############################################
# Python - Cache & bytecode
############################################
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd

############################################
# Lambda Layers (IMPORTANT ADDITION)
# Ignore installed dependencies inside layers
############################################

# Ignore built python dependencies in layers by default,
# but keep checked-in shared layer source under common/
backend/layers/**/python/**
!backend/layers/**/python/common/
!backend/layers/**/python/common/**/
!backend/layers/**/python/common/**/*.py

# Ignore layer build outputs (if you use scripts)
backend/layers/**/build/
backend/layers/**/dist/

############################################
# Logs
############################################
*.log

############################################
# Local CI tooling
############################################
.actrc
.flake8