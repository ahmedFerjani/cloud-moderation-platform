{
  "name": "cloud-moderation-platform",
  "private": true,
  "scripts": {
    "prepare": "husky .husky"
  },
  "lint-staged": {
    "frontend/**/*.{ts,html,scss,css,json,md}": [
      "npm --prefix frontend run prettier:staged --"
    ],
    "frontend/**/*.{ts,html}": [
      "npm --prefix frontend run lint:staged --"
    ],
    "backend/**/*.py": [
      "ruff check",
      "black --check --line-length=100",
      "flake8 --max-line-length=100"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8"
  }
}
